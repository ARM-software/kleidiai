    },
    {
      "name": "cross-baremetal-aarch64-release",
      "configurePreset": "cross-baremetal-aarch64-release"
    },
    {
      "name": "cross-baremetal-arm-debug",
      "configurePreset": "cross-baremetal-arm-debug"
    },
    {
      "name": "cross-baremetal-arm-release",
      "configurePreset": "cross-baremetal-arm-release"
    },
    {
      "name": "android-arm64-v8a-debug",
      "configurePreset": "android-arm64-v8a-debug"
    },
    {
      "name": "android-arm64-v8a-release",
      "configurePreset": "android-arm64-v8a-release"
