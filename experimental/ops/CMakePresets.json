      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "toolchains/cross/cross-linux-arm-gnueabihf.cmake"
      }
    },
    {
      "name": "cross-baremetal-aarch64-debug",
