{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "KLEIDIAI_OPS_C_STANDARD": "11",
        "KLEIDIAI_OPS_CXX_STANDARD": "11"
      }
    },
    {
      "name": "native-linux-aarch64-debug",
      "inherits": "base",
      "displayName": "Native AArch64 Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "toolchains/native/native-linux-aarch64-gnu.cmake"
      }
    },
    {
      "name": "native-linux-aarch64-release",
      "inherits": "base",
      "displayName": "Native AArch64 Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "toolchains/native/native-linux-aarch64-gnu.cmake"
      }
    },
    {
      "name": "cross-linux-aarch64-debug",
      "inherits": "base",
      "displayName": "Cross AArch64 Linux Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "toolchains/cross/cross-linux-aarch64-gnu.cmake"
      }
    },
    {
      "name": "cross-linux-aarch64-release",
      "inherits": "base",
      "displayName": "Cross AArch64 Linux Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "toolchains/cross/cross-linux-aarch64-gnu.cmake"
